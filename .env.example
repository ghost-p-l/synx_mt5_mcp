# SYNX-MT5-MCP Environment Variables
# Copy to .env and configure for your setup
# IMPORTANT: Never commit .env with real credentials!

# ============================================
# Server Configuration
# ============================================
SYNX_CONFIG_PATH=~/.synx-mt5/synx.yaml
SYNX_PROFILE=analyst
SYNX_LOG_LEVEL=INFO
SYNX_STORAGE_PATH=~/.synx-mt5

# ============================================
# Transport Mode
# ============================================
# stdio (default for terminal agents)
# or http for HTTP/SSE transport
SYNX_TRANSPORT=stdio

# HTTP/SSE Configuration (if using http transport)
SYNX_HTTP_HOST=127.0.0.1
SYNX_HTTP_PORT=8765
SYNX_API_KEY=

# ============================================
# Bridge Mode
# ============================================
# python_com (Windows, recommended)
# ea_rest (Cross-platform, requires SYNX_EA)
# wine (Linux via Wine)
SYNX_BRIDGE_MODE=python_com

# Python COM Bridge Options
SYNX_TERMINAL_PATH=

# EA REST Bridge Options
SYNX_EA_HOST=127.0.0.1
SYNX_EA_PORT=18765
SYNX_EA_API_KEY=

# ============================================
# CI/CD Vault Variables (Alternative to Keyring)
# ============================================
# Only use these in CI/CD environments
# Credentials will be consumed at startup and zeroed from memory
# SYNX_VAULT_LOGIN=
# SYNX_VAULT_PASSWORD=
# SYNX_VAULT_SERVER=

# ============================================
# MetaEditor Configuration
# ============================================
SYNX_METAEDITOR_PATH=
SYNX_MQL5_DIR=
